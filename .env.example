# ================================================================
# Sentinel Intelligence — GMP Deviation & CAPA Operations Assistant
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ================================================================

# ── Azure AI Foundry ──────────────────────────────────────────
AZURE_AI_FOUNDRY_PROJECT_CONNECTION_STRING=swedencentral.api.azureml.ms;d16bb0b5-b7b2-4c3b-805b-f7ccb9ce3550;ODL-GHAZ-2177134;<project-name>
AZURE_AI_FOUNDRY_ENDPOINT=https://<project-name>.services.ai.azure.com

# Agent IDs (created by scripts/create_agents.py)
RESEARCH_AGENT_ID=
DOCUMENT_AGENT_ID=
EXECUTION_AGENT_ID=

# ── Azure Cosmos DB ───────────────────────────────────────────
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_DATABASE=sentinel-intelligence
# COSMOS_KEY= # Leave empty to use managed identity (DefaultAzureCredential)

# ── Azure AI Search ───────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
AZURE_SEARCH_KEY=          # Leave empty to use managed identity

# ── Azure Service Bus ─────────────────────────────────────────
SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net
SERVICE_BUS_ALERT_QUEUE=alert-queue

# ── Azure SignalR ─────────────────────────────────────────────
AZURE_SIGNALR_CONNECTION_STRING=Endpoint=https://<service>.service.signalr.net;...

# ── Azure Key Vault ───────────────────────────────────────────
KEY_VAULT_URL=https://<vault>.vault.azure.net/

# ── Azure Storage (Durable Functions + Blob) ─────────────────
DURABLE_STORAGE_CONNECTION=DefaultEndpointsProtocol=https;AccountName=...
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
BLOB_DOCUMENTS_CONTAINER=documents

# ── Azure AD / Entra ID ───────────────────────────────────────
AZURE_TENANT_ID=baf5b083-4c53-493a-8af7-a6ae9812014c
AZURE_CLIENT_ID=2d30c8d5-e4ea-407b-9718-23e5906a3c9d
# AZURE_CLIENT_SECRET=       # Only for service principal auth (not recommended in prod)

# Frontend (Vite uses VITE_ prefix)
VITE_API_BASE_URL=http://localhost:7071/api
VITE_AZURE_TENANT_ID=baf5b083-4c53-493a-8af7-a6ae9812014c
VITE_AZURE_CLIENT_ID=<spa-client-id>
VITE_SIGNALR_ENDPOINT=https://<service>.service.signalr.net

# ── Local dev overrides ───────────────────────────────────────
# Set to "true" to use local mock data instead of Cosmos DB
USE_LOCAL_MOCK_DATA=false
