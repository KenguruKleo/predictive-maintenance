                <mxCell id="e-ea-capa" value="read CAPA" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.35;entryX=0;entryY=0.7;strokeColor=#d6b656;fontStyle=2;fontSize=10;" parent="rg" source="ea" target="c-capa-plans" edge="1">
