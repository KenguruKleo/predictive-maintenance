                <mxCell id="e-ra-equipment" value="get_equipment" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d6b656;fontStyle=2;fontSize=10;" parent="rg" source="ra" target="c-equipment" edge="1">
