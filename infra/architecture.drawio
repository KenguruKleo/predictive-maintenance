                <mxCell id="e-ra-batches" value="get_batch" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.7;entryX=0;entryY=0.5;strokeColor=#d6b656;fontStyle=2;fontSize=10;" parent="rg" source="ra" target="c-batches" edge="1">
