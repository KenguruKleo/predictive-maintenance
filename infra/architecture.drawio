                <mxCell id="e-ra-search" value="vector search" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#d6b656;fontSize=10;" parent="rg" source="ra" target="search" edge="1">
